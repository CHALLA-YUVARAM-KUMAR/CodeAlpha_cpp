#include <iostream>
#include <vector>
#include <string>
#include <chrono>
#include <iomanip>
 
using namespace std;
 
// ─────────────────────────────────────────────
//  Constants
// ─────────────────────────────────────────────
const int N = 9;
 
// ─────────────────────────────────────────────
//  Display Functions (GUI-style Console Output)
// ─────────────────────────────────────────────
 
void printTitle() {
    cout << "\n";
    cout << "  ╔══════════════════════════════════════╗\n";
    cout << "  ║        SUDOKU SOLVER  v1.0           ║\n";
    cout << "  ║   Backtracking Algorithm  |  C++     ║\n";
    cout << "  ╚══════════════════════════════════════╝\n\n";
}
 
void printGrid(const vector<vector<int>>& grid, const string& label = "") {
    if (!label.empty())
        cout << "  [ " << label << " ]\n\n";
 
    cout << "  ┌───────┬───────┬───────┐\n";
    for (int row = 0; row < N; row++) {
        cout << "  │ ";
        for (int col = 0; col < N; col++) {
            if (grid[row][col] == 0)
                cout << "· ";
            else
                cout << grid[row][col] << " ";
 
            if (col == 2 || col == 5)
                cout << "│ ";
        }
        cout << "│\n";
 
        if (row == 2 || row == 5)
            cout << "  ├───────┼───────┼───────┤\n";
    }
    cout << "  └───────┴───────┴───────┘\n\n";
}
 
// ─────────────────────────────────────────────
//  Validation Functions
// ─────────────────────────────────────────────
 
// Check if 'num' is already in the given row
bool isInRow(const vector<vector<int>>& grid, int row, int num) {
    for (int col = 0; col < N; col++)
        if (grid[row][col] == num)
            return true;
    return false;
}
 
// Check if 'num' is already in the given column
bool isInCol(const vector<vector<int>>& grid, int col, int num) {
    for (int row = 0; row < N; row++)
        if (grid[row][col] == num)
            return true;
    return false;
}
 
// Check if 'num' is already in the 3×3 subgrid
bool isInBox(const vector<vector<int>>& grid, int startRow, int startCol, int num) {
    for (int row = 0; row < 3; row++)
        for (int col = 0; col < 3; col++)
            if (grid[startRow + row][startCol + col] == num)
                return true;
    return false;
}
 
// Check all three Sudoku constraints
bool isSafe(const vector<vector<int>>& grid, int row, int col, int num) {
    return !isInRow(grid, row, num)
        && !isInCol(grid, col, num)
        && !isInBox(grid, row - row % 3, col - col % 3, num);
}
 
// ─────────────────────────────────────────────
//  Backtracking Solver
// ─────────────────────────────────────────────
 
bool solveSudoku(vector<vector<int>>& grid) {
    for (int row = 0; row < N; row++) {
        for (int col = 0; col < N; col++) {
 
            // Find an empty cell (represented by 0)
            if (grid[row][col] == 0) {
 
                // Try placing digits 1–9
                for (int num = 1; num <= 9; num++) {
                    if (isSafe(grid, row, col, num)) {
                        grid[row][col] = num;          // Place number
 
                        if (solveSudoku(grid))         // Recurse
                            return true;
 
                        grid[row][col] = 0;            // Backtrack
                    }
                }
                return false; // No valid number found → trigger backtrack
            }
        }
    }
    return true; // All cells filled → puzzle solved!
}
 
// ─────────────────────────────────────────────
//  Input Function
// ─────────────────────────────────────────────
 
vector<vector<int>> getUserInput() {
    vector<vector<int>> grid(N, vector<int>(N, 0));
 
    cout << "  Enter the Sudoku puzzle row by row.\n";
    cout << "  Use 0 for empty cells. Separate digits with spaces.\n\n";
 
    for (int row = 0; row < N; row++) {
        cout << "  Row " << (row + 1) << " : ";
        for (int col = 0; col < N; col++) {
            int val;
            cin >> val;
            while (val < 0 || val > 9) {
                cout << "  ✗ Invalid! Enter digits 0-9: ";
                cin >> val;
            }
            grid[row][col] = val;
        }
    }
    return grid;
}
 
// ─────────────────────────────────────────────
//  Validation: Is the initial puzzle valid?
// ─────────────────────────────────────────────
 
bool isValidPuzzle(const vector<vector<int>>& grid) {
    for (int row = 0; row < N; row++) {
        for (int col = 0; col < N; col++) {
            int val = grid[row][col];
            if (val != 0) {
                // Temporarily remove the value to check placement
                vector<vector<int>> temp = grid;
                temp[row][col] = 0;
                if (!isSafe(temp, row, col, val))
                    return false;
            }
        }
    }
    return true;
}
 
// ─────────────────────────────────────────────
//  Main Function
// ─────────────────────────────────────────────
 
int main() {
    printTitle();
 
    // ── Hard-coded sample puzzle (0 = empty) ──
    vector<vector<int>> puzzle = {
        {5, 3, 0,  0, 7, 0,  0, 0, 0},
        {6, 0, 0,  1, 9, 5,  0, 0, 0},
        {0, 9, 8,  0, 0, 0,  0, 6, 0},
 
        {8, 0, 0,  0, 6, 0,  0, 0, 3},
        {4, 0, 0,  8, 0, 3,  0, 0, 1},
        {7, 0, 0,  0, 2, 0,  0, 0, 6},
 
        {0, 6, 0,  0, 0, 0,  2, 8, 0},
        {0, 0, 0,  4, 1, 9,  0, 0, 5},
        {0, 0, 0,  0, 8, 0,  0, 7, 9}
    };
 
    // ── Menu ──
    cout << "  Choose input method:\n";
    cout << "  [1] Use built-in sample puzzle\n";
    cout << "  [2] Enter your own puzzle\n";
    cout << "\n  Your choice: ";
 
    int choice;
    cin >> choice;
    cout << "\n";
 
    if (choice == 2)
        puzzle = getUserInput();
 
    // ── Display original puzzle ──
    printGrid(puzzle, "ORIGINAL PUZZLE");
 
    // ── Validate puzzle ──
    if (!isValidPuzzle(puzzle)) {
        cout << "  ✗ ERROR: The puzzle contains conflicts and cannot be solved.\n\n";
        return 1;
    }
 
    // ── Solve with timing ──
    cout << "  Solving";
    auto start = chrono::high_resolution_clock::now();
 
    bool solved = solveSudoku(puzzle);
 
    auto end   = chrono::high_resolution_clock::now();
    double ms  = chrono::duration<double, milli>(end - start).count();
 
    cout << " done!\n\n";
 
    // ── Display result ──
    if (solved) {
        printGrid(puzzle, "SOLVED PUZZLE");
        cout << "  ✓ Puzzle solved successfully!\n";
        cout << fixed << setprecision(3);
        cout << "  ⏱  Time taken : " << ms << " ms\n\n";
    } else {
        cout << "  ✗ No solution exists for this puzzle.\n\n";
    }
 
    return 0;
}
